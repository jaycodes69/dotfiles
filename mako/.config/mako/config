# ~/.config/mako/config

# GENERAL SETTINGS
max-history=10
sort=-time
default-timeout=5000
ignore-timeout=0
group-by=app-name,summary
max-visible=5
output=
layer=overlay
anchor=top-right

# STYLE
font=JetBrainsMono Nerd Font 11
background-color=#1F1F28DD
text-color=#DCD7BAFF
border-color=#7E9CD8FF
border-size=2
border-radius=8
padding=10
margin=10
outer-margin=20
width=340
height=120
icons=1
max-icon-size=48
icon-location=left
icon-border-radius=4
markup=1
actions=1
history=1

# FORMAT
format=<b>%s</b>\n%b
text-alignment=left

# BINDINGS
on-button-left=invoke-default-action
on-button-middle=exec makoctl menu -n "$id" dmenu -p 'Select action: '
on-button-right=dismiss

# CRITICAL
[urgency=critical]
background-color=#C34043FF
border-color=#FFA066FF
text-color=#1F1F28FF
default-timeout=0

# WARNING
[urgency=normal]
border-color=#98BB6CFF

# INFO / LOW PRIORITY
[urgency=low]
border-color=#7FB4CAFF

# DO NOT DISTURB MODE
[mode=do-not-disturb]
invisible=1
