#!/bin/sh

### === STARTUP: PREVENT DUPLICATES ===
pgrep -x sxhkd > /dev/null || sxhkd &
setxkbmap -option caps:escape &
pgrep -x dunst > /dev/null || dunst &
pgrep -x flameshot > /dev/null || flameshot &
pgrep -x cliphist > /dev/null || cliphist store &
pgrep -x unclutter > /dev/null || unclutter &
pgrep -x udiskie > /dev/null || udiskie &

### === ENVIRONMENT ===
export BROWSER=brave
export TERMINAL=kitty
export EDITOR=nvim

### === MONITOR SETUP ===
xrandr --output eDP --primary --mode 1366x768 --rate 60

### === WALLPAPER ===
# Kill any running feh instances before setting wallpaper
pgrep -x feh > /dev/null && killall feh
feh --randomize --bg-fill ~/dotfiles/wallpapers/* &

### === COMPOSITOR ===
pgrep -x picom > /dev/null || picom &

### === BSPWM CONFIG ===

# Clear all rules to avoid conflicts
bspc rule -r '*'

# Floating rules for apps
bspc rule -a Gimp desktop=^2 follow=on state=floating
bspc rule -a Brave desktop='^1' follow=on

# Borders and gaps: minimal for max screen space
# bspc config border_width         1
# bspc config window_gap           4
# bspc config top_padding          4
# bspc config bottom_padding       4
# bspc config left_padding         4
# bspc config right_padding        4

# Focus and pointer behavior
bspc config focus_follows_pointer true
bspc config pointer_follows_focus true

# Border colors: subtle and clear
bspc config normal_border_color  "#282c34"
bspc config active_border_color  "#7a98f3"
bspc config focused_border_color "#7a98f3"
bspc config presel_feedback_color "#e06c75"

# Layout options
bspc config split_ratio 0.52
bspc config borderless_monocle true
bspc config gapless_monocle true

# Desktops for single monitor setup
bspc monitor -d 1 2 3 4 5 6 

### === AUTOSTART ===

pgrep -x numlockx > /dev/null || numlockx on &
pgrep -x thunar > /dev/null || thunar --daemon &

### === END ===

